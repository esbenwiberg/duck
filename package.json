{
  "name": "duck",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:todo": "bun run --cwd apps/todo dev",
    "dev:docs": "bun run --cwd apps/docs dev",
    "build:docs": "bun run --cwd apps/docs build",
    "docs:generate": "bun run --cwd packages/docsbot generate",
    "docs:validate": "bun run --cwd packages/docsbot validate",
    "docs:screenshots": "bun run --cwd packages/docsbot screenshots"
  }
}
